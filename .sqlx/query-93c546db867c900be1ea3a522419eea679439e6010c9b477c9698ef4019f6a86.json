{
  "db_name": "PostgreSQL",
  "query": "\n        SELECT m.id            AS \"id!\",\n               m.message_key   AS \"message_key!\",\n               m.uuid,\n               m.parent_uuid,\n               m.seq           AS \"seq!\",\n               m.\"timestamp\",\n               m.type          AS message_type,\n               m.role,\n               m.model,\n               m.stop_reason,\n               m.input_tokens,\n               m.output_tokens,\n               m.cost_usd,\n               m.duration_ms,\n               m.is_sidechain  AS \"is_sidechain!\",\n               m.content\n        FROM messages m\n        WHERE m.session_id = $1\n        ORDER BY m.\"timestamp\" ASC NULLS LAST, m.seq ASC, m.id ASC\n        LIMIT $2 OFFSET $3\n        ",
