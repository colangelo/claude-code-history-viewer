<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!-- dev.cchv.distiller — hourly journal-entries distiller (docs/archive/deployment.md §3c).
     Interval job, NOT KeepAlive: the distiller is catch-up-based (work list derived
     from hub data), and an idle tick is one loopback query + exit (no LLM calls), so
     it ticks hourly (StartInterval) rather than once nightly. Hourly ticks are what
     make the pipeline self-healing: some tick always lands after the 04:00 UTC logical
     day-close regardless of DST offset (the old 05:30-LOCAL calendar run fired 03:30
     UTC under CEST — before the close — so it never saw yesterday), a failed tick
     retries in <=1h instead of +24h, and late laptop-wake data is drained within the
     hour. RunAtLoad adds login/boot catch-up; launchd fires a missed interval once on
     wake. -->
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>dev.cchv.distiller</string>
    <!-- zsh -lc gives a sane PATH via .zprofile, but NOT CLAUDE_CONFIG_DIR: that
         export lives in ~/.zshrc, which non-interactive login shells never read
         (the relay poller works because relay-poll.sh exports it itself). Without
         it claude -p resolves stale credentials and every call 401s, so it must
         be set here explicitly. -->
    <key>ProgramArguments</key>
    <array>
        <string>/bin/zsh</string>
        <string>-lc</string>
        <string>/Users/ac/.local/bin/cchv-distill</string>
    </array>
    <key>EnvironmentVariables</key>
    <dict>
        <key>CCHV_NONINTERACTIVE</key>
        <string>1</string>
        <key>CLAUDE_CONFIG_DIR</key>
        <string>/Users/ac/.config/claude</string>
    </dict>
    <key>StartInterval</key>
    <integer>3600</integer>
    <key>RunAtLoad</key>
    <true/>
    <key>ThrottleInterval</key>
    <integer>300</integer>
    <key>StandardOutPath</key>
    <string>/tmp/cchv-distiller.log</string>
    <key>StandardErrorPath</key>
    <string>/tmp/cchv-distiller.err</string>
</dict>
</plist>
